name = "edge-image-gateway"
main = "src/index.ts"
compatibility_date = "2024-05-31"

[vars]
# 环境标识 (production/development)
ENVIRONMENT = "production"

# 核心仓库配置
GITHUB_USER = "YOUR_GITHUB_USERNAME"
GITHUB_REPO = "YOUR_STORAGE_REPO_NAME"
GITHUB_BRANCH = "main"

[[kv_namespaces]]
binding = "REPO_REGISTRY"
id = "YOUR_KV_NAMESPACE_ID"

[[d1_databases]]
binding = "DB"
database_name = "YOUR_DATABASE_NAME"
database_id = "YOUR_DATABASE_ID"

[[r2_buckets]]
binding = "CACHE_BUCKET"
bucket_name = "YOUR_BUCKET_NAME"

# 页面展示配置
APP_TITLE = "My Edge Image Gateway"
APP_DESCRIPTION = "Ready to serve images from private storage."

# 安全与性能
ALLOWED_REFERERS = "" 
CACHE_TTL_SECONDS = "604800"
ENABLE_SIGNATURE = "false"
RATE_LIMIT_PER_MIN = "120"

# 管理认证
ADMIN_EMAILS = "admin@example.com"
# ADMIN_TOTP_SECRET (通过 wrangler secret put 设置)

# 可选：Cloudflare 集成
# CF_ZONE_ID = "your-zone-id"
# CF_API_TOKEN (通过 wrangler secret put 设置)

# 可选：监控告警
# SENTRY_DSN (通过 wrangler secret put 设置)
# TELEGRAM_BOT_TOKEN (通过 wrangler secret put 设置)
# TELEGRAM_CHAT_ID (通过 wrangler secret put 设置)

# 可选：Analytics Engine
# [[analytics_engine_datasets]]
# binding = "ANALYTICS_ENGINE"
# dataset = "edge_image_gateway"

[env.preview]
name = "img-proxy-preview"
vars = { ALLOWED_REFERERS = "preview.yourdomain.com" }

[env.production]
name = "img-proxy"
# routes = [{ pattern = "your-custom-domain.com/*", custom_domain = true }]
